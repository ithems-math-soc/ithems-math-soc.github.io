   "source": [
    "from PIL import Image"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "a3d36d44-ecc0-4b2b-8f8a-b4eb68924c5f",
   "metadata": {},
   "outputs": [],
   "source": [
    "img = Image.open(\"apple-touch-icon-precomposed.jpeg\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "bf247b86-0c5b-41ef-8d6b-e0c0a496f188",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ensure square (optional crop)\n",
    "img = img.resize((64, 64))\n",
    "\n",
    "# Save as favicon with multiple sizes\n",
    "img.save(\"favicon.ico\", format=\"ICO\", sizes=[(16,16), (32,32), (48,48)])"
   ]
  },
